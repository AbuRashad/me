# AI backend: "ollama" (local, default) or "anthropic" (cloud)
AI_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
# For cloud mode:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Database — SQLite for dev, swap to PostgreSQL+pgvector for prod:
DATABASE_URL=sqlite+aiosqlite:///./abdoos.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/abdoos
CORS_ORIGINS=http://localhost:5173
